# =============================================================================
# Variables de entorno — App Telemedicina
# Copiá este archivo a `.env` y completá los valores. Nunca commitear `.env`.
# =============================================================================

# --- App ---
APP_BASE_URL=https://telemedicina.lionapp.cloud
NODE_ENV=production

# --- GHCR (producción con docker-compose.prod.yml) ---
GHCR_OWNER=lelion13
IMAGE_TAG=latest

# --- MongoDB (compose usa servicio interno; override solo si DB externa) ---
MONGODB_URI=mongodb://mongo:27017/telemedicina

# --- NextAuth ---
NEXTAUTH_URL=https://telemedicina.lionapp.cloud
NEXTAUTH_SECRET=generar-con-openssl-rand-base64-32
AUTH_SECRET=generar-con-openssl-rand-base64-32

# --- JWT paciente (link /consulta/[token]) ---
PATIENT_TOKEN_SECRET=generar-secreto-distinto-a-nextauth

# --- Ventana de validez del link paciente (minutos) ---
TOKEN_VALID_BEFORE_MIN=15
TOKEN_VALID_AFTER_MIN=60

# --- GPS ---
GPS_ACCURACY_THRESHOLD_M=1000

# --- Retención auditoría (RegistroGPS + LogConsulta, meses) ---
AUDIT_RETENTION_MONTHS=24

# --- LiveKit ---
LIVEKIT_API_KEY=tu-api-key
LIVEKIT_API_SECRET=tu-api-secret
LIVEKIT_URL=wss://livekit.telemedicina.lionapp.cloud
# IP pública del VPS — necesaria para WebRTC
LIVEKIT_NODE_IP=

# --- SMTP (Nodemailer) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Telemedicina Lion <noreply@lionapp.cloud>

# --- Seed admin (solo para npm run seed) ---
ADMIN_EMAIL=admin@lionapp.cloud
ADMIN_PASSWORD=
ADMIN_NOMBRE=Admin
ADMIN_APELLIDO=Sistema
APP_HOST=telemedicina.lionapp.cloud
LIVEKIT_HOST=livekit.telemedicina.lionapp.cloud
TRAEFIK_NETWORK=traefik
TRAEFIK_CERT_RESOLVER=letsencrypt
